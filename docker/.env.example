# stonefish-ws compose 변수 — 이 파일을 .env로 복사해 머신별 값을 채운다.
# (개인값은 compose/Dockerfile에 하드코딩하지 않는다 — omp-env 결의)

# 호스트 사용자와 컨테이너 사용자 UID/GID 일치 (bind-mount 소유권)
#   UID=$(id -u), GID=$(id -g)
UID=1000
GID=1000

# 워크스페이스 루트 (기본: <repo>/docker/ 기준 ../../..)
#WS_DIR=../../..

# 이미지 네임스페이스·태그
#DOCKER_NAMESPACE=hero-lab-postech
#IMAGE_TAG=humble-1.3.0

# Stonefish 코어 ref 고정 (기본 main; 재현성 필요시 태그/커밋으로)
#STONEFISH_REF=main

# GPU 선택 (기본 all; 특정 GPU만: 0 또는 1 등)
#NVIDIA_VISIBLE_DEVICES=all
